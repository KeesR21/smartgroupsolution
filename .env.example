# The PUBLIC website runs with no database. These variables are only used by
# the /admin CMS (login + session). Copy to `.env` and adjust for your setup.

# --- Admin login (env-based auth, no database) ---
ADMIN_EMAIL="admin@smartgroupsolution.com"
ADMIN_PASSWORD="Admin123!"
# Optional: bcrypt hash of the password (takes precedence over ADMIN_PASSWORD)
# ADMIN_PASSWORD_HASH=""
ADMIN_NAME="Administrator"

# --- Session signing (NextAuth) ---
# OPTIONAL: if omitted, a secret is auto-generated and persisted to
# data/auth-secret on first run. Set it explicitly to keep sessions valid
# across servers/restarts (recommended for production, esp. multi-instance).
# Generate one with: openssl rand -base64 48
# NEXTAUTH_SECRET="change-this-to-a-long-random-string-in-production"

# OPTIONAL: set to your public URL in production, e.g. https://yourdomain.com
# NEXTAUTH_URL="http://localhost:3000"

# --- Content store (optional) ---
# Where the JSON content file is written. Defaults to ./data/content.json
# CONTENT_FILE="./data/content.json"
